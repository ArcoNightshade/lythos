      "Bash(nm target/x86_64-lythos/debug/lythos)",
      "Bash(readelf -h target/x86_64-lythos/debug/lythos)",
      "Bash(brew list:*)",
      "Bash(RUSTFLAGS=\"-C link-arg=-Tlinker.ld -C link-arg=-Map=kernel.map\" cargo build --target x86_64-lythos.json)",
      "Bash(grep -E \"\\(exception|gdt_flush|isr_stub_table|isr_stub_0$|IDT\\)\")",
      "Bash(grep -v \"^warning\\\\|^  -->\\\\|^   |\\\\|^$\\\\|= note\\\\|= help\\\\|cargo fix\")",
      "Bash(qemu-system-x86_64 -kernel target/x86_64-lythos/debug/lythos -serial stdio -display none)",
      "Bash(wc:*)"

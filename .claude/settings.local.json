      "Bash(rustc --version)",
      "Bash(cargo --version)",
      "Bash(RUSTFLAGS=\"-Zjson-target-spec\" cargo build)",
      "Bash(RUSTFLAGS=\"-Zjson-target-specs\" cargo build)",
      "Bash(rustc -Z help)",

      "Bash(rustc --print target-spec-json --target x86_64-unknown-none)",
      "Bash(rustc:*)",
      "Bash(llvm-objdump -f target/x86_64-lythos/debug/lythos)",
      "Bash(rust-objdump -f target/x86_64-lythos/debug/lythos)",
